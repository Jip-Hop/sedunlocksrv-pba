#!/bin/busybox ash

# sedunlocksrv-net configures the PBA runtime network. It is called during boot
# by tc-config and can also be called by the console TUI after updating
# /etc/sedunlocksrv.conf.

CONFIG_PATH="${SEDUNLOCKSRV_CONFIG:-/etc/sedunlocksrv.conf}"

NET_MODE="single"
NET_IFACES=""
NET_EXCLUDE=""
NET_DHCP="true"
IP_ADDR=""
NETMASK=""
GATEWAY=""
DNS=""
BOND_NAME="bond0"
BOND_MODE="4"
BOND_MIIMON="100"
BOND_LACP_RATE="1"
BOND_XMIT_HASH_POLICY="1"

[ -f "${CONFIG_PATH}" ] && . "${CONFIG_PATH}"

normalize_bool() {
    case "$1" in
        1|true|TRUE|yes|YES|on|ON) echo "true" ;;
        *)                          echo "false" ;;
    esac
}

NET_DHCP=$(normalize_bool "${NET_DHCP}")

have_command() {
    command -v "$1" >/dev/null 2>&1
}

valid_ipv4_octet() {
    case "$1" in
        [0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5]) return 0 ;;
        *) return 1 ;;
    esac
}

valid_ipv4() {
    local old_ifs
    case "$1" in
        ''|*[!0-9.]*)
            return 1
            ;;
    esac
    old_ifs="${IFS}"
    IFS=.
    set -- $1
    IFS="${old_ifs}"
    [ "$#" -eq 4 ] || return 1
    valid_ipv4_octet "$1" || return 1
    valid_ipv4_octet "$2" || return 1
    valid_ipv4_octet "$3" || return 1
    valid_ipv4_octet "$4" || return 1
    return 0
}

usable_ipv4() {
    valid_ipv4 "$1" || return 1
    case "$1" in
        0.0.0.0|255.255.255.255) return 1 ;;
        *) return 0 ;;
    esac
}

valid_netmask() {
    case "$1" in
        128.0.0.0|192.0.0.0|224.0.0.0|240.0.0.0|248.0.0.0|252.0.0.0|254.0.0.0|255.0.0.0|\
255.128.0.0|255.192.0.0|255.224.0.0|255.240.0.0|255.248.0.0|255.252.0.0|255.254.0.0|255.255.0.0|\
255.255.128.0|255.255.192.0|255.255.224.0|255.255.240.0|255.255.248.0|255.255.252.0|255.255.254.0|255.255.255.0|\
255.255.255.128|255.255.255.192|255.255.255.224|255.255.255.240|255.255.255.248|255.255.255.252|255.255.255.254|255.255.255.255)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

validate_network_values() {
    local dns_item
    case "${NET_MODE}" in
        single|bond) ;;
        *)
            echo "[net] Invalid NET_MODE='${NET_MODE}'"
            return 1
            ;;
    esac
    case "${NET_DHCP}" in
        true|false) ;;
        *)
            echo "[net] Invalid NET_DHCP='${NET_DHCP}'"
            return 1
            ;;
    esac
    if [ "${NET_DHCP}" = "false" ]; then
        if [ -z "${IP_ADDR}" ] || [ -z "${NETMASK}" ]; then
            echo "[net] Static networking requires IP_ADDR and NETMASK"
            return 1
        fi
        if ! usable_ipv4 "${IP_ADDR}"; then
            echo "[net] Invalid IP_ADDR='${IP_ADDR}'"
            return 1
        fi
        if ! valid_netmask "${NETMASK}"; then
            echo "[net] Invalid NETMASK='${NETMASK}'"
            return 1
        fi
        if [ -n "${GATEWAY}" ] && ! usable_ipv4 "${GATEWAY}"; then
            echo "[net] Invalid GATEWAY='${GATEWAY}'"
            return 1
        fi
        for dns_item in ${DNS}; do
            if ! usable_ipv4 "${dns_item}"; then
                echo "[net] Invalid DNS server='${dns_item}'"
                return 1
            fi
        done
    fi
    return 0
}

append_word() {
    if [ -n "$1" ]; then
        printf '%s %s\n' "$1" "$2"
    else
        printf '%s\n' "$2"
    fi
}

contains_word() {
    local needle="$1"
    shift
    for item in "$@"; do
        [ "${item}" = "${needle}" ] && return 0
    done
    return 1
}

list_all_ifaces() {
    local path iface
    for path in /sys/class/net/*; do
        [ -e "${path}" ] || continue
        iface=${path##*/}
        case "${iface}" in
            lo|bonding_masters) continue ;;
        esac
        echo "${iface}"
    done
}

list_detected_ifaces() {
    local iface found=""
    for iface in $(list_all_ifaces); do
        [ -e "/sys/class/net/${iface}/device" ] || continue
        echo "${iface}"
        found="yes"
    done
    [ -n "${found}" ] && return 0
    list_all_ifaces
}

build_iface_list() {
    local requested iface result="" exclude_items
    exclude_items="${NET_EXCLUDE}"
    requested="${NET_IFACES}"

    if [ -n "${requested}" ]; then
        for iface in ${requested}; do
            [ -d "/sys/class/net/${iface}" ] || continue
            contains_word "${iface}" ${exclude_items} && continue
            result="$(append_word "${result}" "${iface}")"
        done
    else
        for iface in $(list_detected_ifaces); do
            contains_word "${iface}" ${exclude_items} && continue
            result="$(append_word "${result}" "${iface}")"
        done
    fi
    printf '%s\n' "${result}"
}

count_words() {
    set -- $1
    echo $#
}

wait_for_iface_link() {
    local iface="$1" seconds="$2" state count=0
    while [ "${count}" -lt "${seconds}" ]; do
        state=$(cat "/sys/class/net/${iface}/operstate" 2>/dev/null || echo "unknown")
        case "${state}" in
            up|unknown) return 0 ;;
        esac
        sleep 1
        count=$((count + 1))
    done
    return 1
}

write_resolv_conf() {
    [ -n "${DNS}" ] || return 0
    {
        for dns_item in ${DNS}; do
            printf 'nameserver %s\n' "${dns_item}"
        done
    } > /etc/resolv.conf
}

clear_default_route() {
    route del default >/dev/null 2>&1 || true
}

configure_static_ipv4() {
    local iface="$1"
    if [ -z "${IP_ADDR}" ] || [ -z "${NETMASK}" ]; then
        echo "[net] Static networking skipped on ${iface}: IP_ADDR or NETMASK is missing"
        return 1
    fi
    clear_default_route
    ifconfig "${iface}" "${IP_ADDR}" netmask "${NETMASK}" up || return 1
    [ -n "${GATEWAY}" ] && route add default gw "${GATEWAY}" "${iface}" >/dev/null 2>&1
    write_resolv_conf
    return 0
}

configure_dhcp_ipv4() {
    local iface="$1"
    clear_default_route
    ifconfig "${iface}" up || return 1
    if ! have_command udhcpc; then
        echo "[net] DHCP requested but udhcpc is unavailable"
        return 1
    fi
    udhcpc -n -q -t 5 -T 3 -i "${iface}" >/dev/null 2>&1
}

configure_iface_ipv4() {
    local iface="$1"
    if [ "${NET_DHCP}" = "true" ]; then
        configure_dhcp_ipv4 "${iface}"
        return $?
    fi
    configure_static_ipv4 "${iface}"
}

release_bond_if_present() {
    local iface slaves
    [ -d "/sys/class/net/${BOND_NAME}/bonding" ] || return 0
    ifconfig "${BOND_NAME}" down >/dev/null 2>&1 || true
    slaves="$(cat "/sys/class/net/${BOND_NAME}/bonding/slaves" 2>/dev/null || true)"
    for iface in ${slaves}; do
        echo "-${iface}" > "/sys/class/net/${BOND_NAME}/bonding/slaves" 2>/dev/null || true
        ifconfig "${iface}" down >/dev/null 2>&1 || true
    done
}

configure_individual_ifaces() {
    local ifaces="$1" iface configured=0
    release_bond_if_present
    if [ -z "${ifaces}" ]; then
        echo "[net] No eligible interfaces found after exclusions"
        return 1
    fi
    if [ "${NET_DHCP}" = "false" ] && [ "$(count_words "${ifaces}")" -gt 1 ]; then
        set -- ${ifaces}
        ifaces="$1"
        echo "[net] Static mode with multiple interfaces; using ${ifaces} only"
    fi
    for iface in ${ifaces}; do
        echo "[net] Configuring ${iface} (${NET_DHCP})"
        if configure_iface_ipv4 "${iface}"; then
            configured=1
        else
            echo "[net] ${iface} configuration failed"
        fi
    done
    [ "${configured}" -eq 1 ]
}

create_bond() {
    local bond_ifaces="$1" bond_mode="$2" iface

    if ! have_command modprobe && [ ! -x /sbin/modprobe ]; then
        echo "[net] modprobe command not available"
        return 1
    fi

    if ! /sbin/modprobe bonding >/dev/null 2>&1; then
        echo "[net] bonding module unavailable"
        return 1
    fi

    if [ ! -d "/sys/class/net/${BOND_NAME}" ]; then
        echo "+${BOND_NAME}" > /sys/class/net/bonding_masters 2>/dev/null || true
    fi
    [ -d "/sys/class/net/${BOND_NAME}" ] || return 1

    release_bond_if_present
    ifconfig "${BOND_NAME}" down >/dev/null 2>&1 || true
    echo "${bond_mode}"             > "/sys/class/net/${BOND_NAME}/bonding/mode"
    echo "${BOND_MIIMON}"           > "/sys/class/net/${BOND_NAME}/bonding/miimon"
    echo "${BOND_LACP_RATE}"        > "/sys/class/net/${BOND_NAME}/bonding/lacp_rate"
    echo "${BOND_XMIT_HASH_POLICY}" > "/sys/class/net/${BOND_NAME}/bonding/xmit_hash_policy"

    for iface in ${bond_ifaces}; do
        ifconfig "${iface}" down >/dev/null 2>&1 || true
        echo "+${iface}" > "/sys/class/net/${BOND_NAME}/bonding/slaves" 2>/dev/null || true
    done

    echo "[net] Bond ${BOND_NAME}: mode=${bond_mode} miimon=${BOND_MIIMON} lacp_rate=${BOND_LACP_RATE} xmit_hash_policy=${BOND_XMIT_HASH_POLICY}"

    if ! wait_for_iface_link "${BOND_NAME}" 30; then
        echo "[net] ${BOND_NAME} did not report link-up within 30s; proceeding anyway"
    fi

    configure_iface_ipv4 "${BOND_NAME}"
}

configure_network() {
    local candidates iface_count
    candidates="$(build_iface_list)"
    iface_count="$(count_words "${candidates}")"

    echo "----------------------------------------------------"
    echo "[net] Mode=${NET_MODE} DHCP=${NET_DHCP} Exclude='${NET_EXCLUDE}'"
    echo "[net] Candidates: ${candidates:-none}"
    echo "----------------------------------------------------"

    case "${NET_MODE}" in
        bond)
            if [ "${iface_count}" -lt 2 ]; then
                echo "[net] Bonding requested but <2 interfaces available; using individual mode"
                configure_individual_ifaces "${candidates}"
                return $?
            fi
            create_bond "${candidates}" "${BOND_MODE}"
            return $?
            ;;
        single)
            configure_individual_ifaces "${candidates}"
            return $?
            ;;
    esac
}

run_network_setup() {
    if ! validate_network_values; then
        echo "[net] Network configuration invalid; console unlock will still run"
        return 1
    fi

    if configure_network; then
        echo "[net] Network configuration complete"
        return 0
    fi

    echo "[net] Network configuration unavailable; console unlock will still run"
    return 1
}

case "${1:---configure}" in
    --configure)
        run_network_setup
        ;;
    --validate)
        validate_network_values
        ;;
    *)
        echo "Usage: sedunlocksrv-net [--configure|--validate]" >&2
        exit 2
        ;;
esac
