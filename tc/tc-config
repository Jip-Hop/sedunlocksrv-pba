#!/bin/busybox ash

# Custom Tiny Core Linux RC Script

# Set kernel logging level to 3 (errors only) to hide non-critical hardware warnings
dmesg -n 3

# Hide cursor
echo -e "\e[?1c"
# Disable showing keyboard input
stty -echo
# Disable input buffering
stty cbreak min 1

# ANSI COLORS
GREEN="$(echo -e '\033[1;32m')"
MAGENTA="$(echo -e '\033[1;35m')"
NORMAL="$(echo -e '\033[0;39m')"

export PATH=/usr/local/sbin:/usr/local/bin:"$PATH"

# Start Udev to populate /dev and handle hotplug events
/sbin/udevd --daemon 2>&1 >/dev/null
/sbin/udevadm trigger --action=add 2>&1 >/dev/null &

# Setup clock
while [ ! -e /dev/rtc0 ]; do usleep 50000; done
/sbin/hwclock -u -s &

/sbin/ifconfig lo 127.0.0.1 up
/sbin/route add 127.0.0.1 lo &

# Creates the necessary links and cache to the most recent shared libraries
/sbin/ldconfig 2>/dev/null

# This waits until all devices have registered
/sbin/udevadm settle --timeout=5

# --- LACP (802.3ad) via sysfs  ---
echo "----------------------------------------------------"
echo "🚀 Starting Network Configuration: LACP Bond0"
echo "----------------------------------------------------"

# requires the inclusion of the ipv6_netfilter package which includes the bonding driver
# 1. Load Driver
echo -n "Step 1: Loading bonding kernel module... "
modprobe bonding && echo "OK" || echo "FAILED"

# 2. Create Interface (only if it doesn't already exist)
echo -n "Step 2: Ensuring bond0 interface exists... "
if [ ! -d "/sys/class/net/bond0" ]; then
    echo +bond0 > /sys/class/net/bonding_masters && echo "CREATED"
else
    echo "ALREADY EXISTS (skipping creation)"
fi

# 3. Configure LACP Parameters
echo "Step 3: Setting LACP (Mode 4) parameters..."
echo 4 > /sys/class/net/bond0/bonding/mode
echo 100 > /sys/class/net/bond0/bonding/miimon
echo 1 > /sys/class/net/bond0/bonding/lacp_rate
echo 1 > /sys/class/net/bond0/bonding/xmit_hash_policy
echo "   [✓] Mode: 802.3ad (LACP)"
echo "   [✓] Rate: Fast (1s)"
echo "   [✓] Hash: Layer2+3"

# 4. Enslave eth0 and eth1
echo "Step 4: Enslaving physical adapters..."
for iface in eth0 eth1; do
    if [ -d "/sys/class/net/$iface" ]; then
        echo -n "   -> Enslaving $iface... "
        ifconfig "$iface" down  # <-- Changed from 'ip link set'
        echo "+$iface" > /sys/class/net/bond0/bonding/slaves && echo "DONE"
    else
        echo "   [!] Skipping $iface: Device not found."
    fi
done

# 5. Network Addressing
echo "Step 5: Applying static network configuration..."
ifconfig bond0 192.168.10.230 netmask 255.255.255.0 up  # <-- Changed from 'ip addr'
echo "   [✓] IP Address: 192.168.10.230/24"

route add default gw 192.168.10.253 bond0  # <-- Changed from 'ip route'
echo "   [✓] Gateway:    192.168.10.253"

echo "nameserver 192.168.10.252" > /etc/resolv.conf
echo "   [✓] DNS Server: 192.168.10.252"

# 6. Connectivity Test
echo "----------------------------------------------------"
echo "⏳ Waiting 10s for LACP Handshake with switch..."
sleep 10

echo -n "🔍 Testing connectivity to gateway... "
if ping -c 3 -W 5 192.168.10.253 > /dev/null; then
    echo "SUCCESS!"
    echo "✅ Network is ONLINE."
else
    echo "FAILED."
    echo "⚠️  ERROR: Gateway is unreachable."
    echo "--- Kernel Bond Status ---"
    [ -f /proc/net/bonding/bond0 ] && cat /proc/net/bonding/bond0 | grep -E 'Bonding Mode|MII Status|Slave Interface|Partner'
    echo "--------------------------"
fi
echo "----------------------------------------------------"

# Fix to get the 64-bit binaries working
if [ ! -d /lib64 ]; then
    ln -s /lib /lib64
fi

if [ -e /home/tc/keymap ]; then
    KEYMAP=$(cat /home/tc/keymap)
    keymapfile=$(find /usr/share/kmap/ -name "${KEYMAP}.kmap")
    echo "Loading keymapfile $keymapfile"
    loadkmap < $keymapfile
fi

sedutil-cli --scan

cd /usr/local/sbin/sedunlocksrv/
./sedunlocksrv

# Reboot when sedunlocksrv exits
echo "Rebooting..."
sleep 3
reboot -nf
