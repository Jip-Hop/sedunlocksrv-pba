#!/bin/busybox ash

# ----------------------------------------------------
# Custom Tiny Core Linux RC Script
# ----------------------------------------------------

restore_terminal() {
    stty sane 2>/dev/null || true
    printf '\033[?25h'
    echo
    echo "[!] Terminal restored"
}

trap restore_terminal EXIT

dmesg -n 3
printf '\033[?25l'
stty cbreak min 1

export PATH=/usr/local/sbin:/usr/local/bin:"$PATH"

# ----------------------------------------------------
# UDEV + CLOCK
# ----------------------------------------------------
/sbin/udevd --daemon >/dev/null 2>&1
/sbin/udevadm trigger --action=add >/dev/null 2>&1 &

while [ ! -e /dev/rtc0 ]; do usleep 50000; done
/sbin/hwclock -u -s &

/sbin/ifconfig lo 127.0.0.1 up
/sbin/route add 127.0.0.1 lo >/dev/null 2>&1 &

/sbin/ldconfig 2>/dev/null
/sbin/udevadm settle --timeout=5

# ----------------------------------------------------
# Runtime network config
# ----------------------------------------------------
NET_MODE="single"
NET_IFACES=""
NET_EXCLUDE=""
NET_DHCP="true"
IP_ADDR=""
NETMASK=""
GATEWAY=""
DNS=""
BOND_NAME="bond0"
BOND_MODE="4"
BOND_MIIMON="100"
BOND_LACP_RATE="1"
BOND_XMIT_HASH_POLICY="1"
EXPERT_PASSWORD_HASH=""

[ -f /etc/sedunlocksrv.conf ] && . /etc/sedunlocksrv.conf
export EXPERT_PASSWORD_HASH

normalize_bool() {
    case "$1" in
        1|true|TRUE|yes|YES|on|ON) echo "true" ;;
        *)                          echo "false" ;;
    esac
}

NET_DHCP=$(normalize_bool "${NET_DHCP}")

have_command() {
    command -v "$1" >/dev/null 2>&1
}

append_word() {
    if [ -n "$1" ]; then
        printf '%s %s\n' "$1" "$2"
    else
        printf '%s\n' "$2"
    fi
}

contains_word() {
    local needle="$1"
    shift
    for item in "$@"; do
        [ "${item}" = "${needle}" ] && return 0
    done
    return 1
}

list_all_ifaces() {
    local path iface
    for path in /sys/class/net/*; do
        [ -e "${path}" ] || continue
        iface=${path##*/}
        case "${iface}" in
            lo|bonding_masters) continue ;;
        esac
        echo "${iface}"
    done
}

list_detected_ifaces() {
    local iface found=""
    for iface in $(list_all_ifaces); do
        [ -e "/sys/class/net/${iface}/device" ] || continue
        echo "${iface}"
        found="yes"
    done
    [ -n "${found}" ] && return 0
    list_all_ifaces
}

build_iface_list() {
    local requested iface result="" exclude_items
    exclude_items="${NET_EXCLUDE}"
    requested="${NET_IFACES}"

    if [ -n "${requested}" ]; then
        for iface in ${requested}; do
            [ -d "/sys/class/net/${iface}" ] || continue
            contains_word "${iface}" ${exclude_items} && continue
            result="$(append_word "${result}" "${iface}")"
        done
    else
        for iface in $(list_detected_ifaces); do
            contains_word "${iface}" ${exclude_items} && continue
            result="$(append_word "${result}" "${iface}")"
        done
    fi
    printf '%s\n' "${result}"
}

count_words() {
    set -- $1
    echo $#
}

wait_for_iface_link() {
    local iface="$1" seconds="$2" state count=0
    while [ "${count}" -lt "${seconds}" ]; do
        state=$(cat "/sys/class/net/${iface}/operstate" 2>/dev/null || echo "unknown")
        case "${state}" in
            up|unknown) return 0 ;;
        esac
        sleep 1
        count=$((count + 1))
    done
    return 1
}

# write_resolv_conf — writes /etc/resolv.conf atomically in one printf call
# rather than truncate-then-append-in-a-loop. (Fix #12)
write_resolv_conf() {
    [ -n "${DNS}" ] || return 0
    {
        for dns_item in ${DNS}; do
            printf 'nameserver %s\n' "${dns_item}"
        done
    } > /etc/resolv.conf
}

configure_static_ipv4() {
    local iface="$1"
    if [ -z "${IP_ADDR}" ] || [ -z "${NETMASK}" ]; then
        echo "[net] Static networking skipped on ${iface}: IP_ADDR or NETMASK is missing"
        return 1
    fi
    ifconfig "${iface}" "${IP_ADDR}" netmask "${NETMASK}" up || return 1
    [ -n "${GATEWAY}" ] && route add default gw "${GATEWAY}" "${iface}" >/dev/null 2>&1
    write_resolv_conf
    return 0
}

configure_dhcp_ipv4() {
    local iface="$1"
    ifconfig "${iface}" up || return 1
    if ! have_command udhcpc; then
        echo "[net] DHCP requested but udhcpc is unavailable"
        return 1
    fi
    # DHCP logs go to /dev/null — they contain no information useful at runtime
    # and writing to /tmp is unnecessarily noisy. (Fix implicit in cleanup)
    udhcpc -n -q -t 5 -T 3 -i "${iface}" >/dev/null 2>&1
}

configure_iface_ipv4() {
    local iface="$1"
    if [ "${NET_DHCP}" = "true" ]; then
        configure_dhcp_ipv4 "${iface}"
        return $?
    fi
    configure_static_ipv4 "${iface}"
}

configure_individual_ifaces() {
    local ifaces="$1" iface configured=0
    if [ -z "${ifaces}" ]; then
        echo "[net] No eligible interfaces found after exclusions"
        return 1
    fi
    if [ "${NET_DHCP}" = "false" ] && [ "$(count_words "${ifaces}")" -gt 1 ]; then
        set -- ${ifaces}
        ifaces="$1"
        echo "[net] Static mode with multiple interfaces; using ${ifaces} only"
    fi
    for iface in ${ifaces}; do
        echo "[net] Configuring ${iface} (${NET_DHCP})"
        if configure_iface_ipv4 "${iface}"; then
            configured=1
        else
            echo "[net] ${iface} configuration failed"
        fi
    done
    [ "${configured}" -eq 1 ]
}

create_bond() {
    local bond_ifaces="$1" bond_mode="$2" iface

    if ! modprobe bonding >/dev/null 2>&1; then
        echo "[net] bonding module unavailable"
        return 1
    fi

    if [ ! -d "/sys/class/net/${BOND_NAME}" ]; then
        echo "+${BOND_NAME}" > /sys/class/net/bonding_masters 2>/dev/null || true
    fi
    [ -d "/sys/class/net/${BOND_NAME}" ] || return 1

    ifconfig "${BOND_NAME}" down >/dev/null 2>&1 || true
    echo "${bond_mode}"            > "/sys/class/net/${BOND_NAME}/bonding/mode"
    echo "${BOND_MIIMON}"          > "/sys/class/net/${BOND_NAME}/bonding/miimon"
    echo "${BOND_LACP_RATE}"       > "/sys/class/net/${BOND_NAME}/bonding/lacp_rate"
    echo "${BOND_XMIT_HASH_POLICY}" > "/sys/class/net/${BOND_NAME}/bonding/xmit_hash_policy"

    for iface in ${bond_ifaces}; do
        ifconfig "${iface}" down >/dev/null 2>&1 || true
        echo "+${iface}" > "/sys/class/net/${BOND_NAME}/bonding/slaves" 2>/dev/null || true
    done

    echo "[net] Bond ${BOND_NAME}: mode=${bond_mode} miimon=${BOND_MIIMON} lacp_rate=${BOND_LACP_RATE} xmit_hash_policy=${BOND_XMIT_HASH_POLICY}"

    # wait_for_iface_link returns as soon as the interface reports link-up,
    # so the 30-second maximum is only paid when the bond genuinely doesn't
    # come up. The warning is diagnostic; we proceed regardless. (Fix #13)
    if ! wait_for_iface_link "${BOND_NAME}" 30; then
        echo "[net] ${BOND_NAME} did not report link-up within 30s — proceeding anyway"
    fi

    configure_iface_ipv4 "${BOND_NAME}"
}

configure_network() {
    local candidates iface_count
    candidates="$(build_iface_list)"
    iface_count="$(count_words "${candidates}")"

    echo "----------------------------------------------------"
    echo "[net] Mode=${NET_MODE} DHCP=${NET_DHCP} Exclude='${NET_EXCLUDE}'"
    echo "[net] Candidates: ${candidates:-none}"
    echo "----------------------------------------------------"

    case "${NET_MODE}" in
        bond)
            if [ "${iface_count}" -lt 2 ]; then
                echo "[net] Bonding requested but <2 interfaces available; using individual mode"
                configure_individual_ifaces "${candidates}"
                return $?
            fi
            create_bond "${candidates}" "${BOND_MODE}"
            return $?
            ;;
        single)
            configure_individual_ifaces "${candidates}"
            return $?
            ;;
        *)
            echo "[net] Unknown NET_MODE='${NET_MODE}', skipping network setup"
            return 1
            ;;
    esac
}

print_intel_700_diagnostics() {
    local i40e_module dmesg_lines pci_lines

    echo "----------------------------------------------------"
    echo "[diag] Intel 700-series NIC diagnostics"

    i40e_module="$(find /lib/modules -type f -name 'i40e.ko*' | head -n1)"
    if [ -n "${i40e_module}" ] && [ -f "${i40e_module}" ]; then
        echo "[diag] i40e module present: ${i40e_module}"
    else
        echo "[diag] i40e module not found in /lib/modules"
    fi

    if grep -q '^i40e ' /proc/modules 2>/dev/null; then
        echo "[diag] i40e module loaded"
    else
        echo "[diag] i40e module not loaded"
    fi

    if have_command lspci; then
        pci_lines="$(lspci -nn 2>/dev/null | grep -Ei 'Ethernet|Network|X710|XL710|XXV710|Intel Corporation' | head -n10)"
        [ -n "${pci_lines}" ] && printf '%s\n' "${pci_lines}" | sed 's/^/[diag] pci: /'
    fi

    dmesg_lines="$(dmesg 2>/dev/null | grep -Ei 'i40e|X710|XL710|XXV710|firmware|NVM' | tail -n15)"
    if [ -n "${dmesg_lines}" ]; then
        printf '%s\n' "${dmesg_lines}" | sed 's/^/[diag] dmesg: /'
    else
        echo "[diag] no Intel 700-series related dmesg lines found"
    fi
    echo "----------------------------------------------------"
}

print_intel_700_diagnostics

if configure_network; then
    echo "[net] Network configuration complete"
else
    echo "[net] Network configuration unavailable; console unlock will still start"
fi

# ----------------------------------------------------
# SYSTEM FIXES
# ----------------------------------------------------
[ ! -d /lib64 ] && ln -s /lib /lib64

# Keymap
if [ -e /home/tc/keymap ]; then
    KEYMAP=$(cat /home/tc/keymap)
    keymapfile=$(find /usr/share/kmap/ -name "${KEYMAP}.kmap")
    if [ -n "${keymapfile}" ] && [ -f "${keymapfile}" ]; then
        loadkmap < "$keymapfile"
    else
        echo "[keymap] Requested keymap not found: ${KEYMAP}"
    fi
fi

# ----------------------------------------------------
# START SERVICE
# ----------------------------------------------------
cd /usr/local/sbin/sedunlocksrv/

echo "Starting sedunlocksrv..."
exec ./sedunlocksrv

# ----------------------------------------------------
# FALLBACK (only if exec fails)
# ----------------------------------------------------
echo "sedunlocksrv exited unexpectedly"
sleep 30
reboot -f
