#!/bin/busybox ash

# ----------------------------------------------------
# Custom Tiny Core Linux RC Script (Improved)
# ----------------------------------------------------

# Ensure terminal is restored on exit
trap "stty sane; echo; echo '[!] Terminal restored';" EXIT

# Reduce kernel log noise
dmesg -n 3

# Hide cursor (sedunlocksrv console TUI resets terminal as needed)
echo -e "\e[?25l"

# Minimal input mode until sedunlocksrv takes over (raw mode in Go)
stty cbreak min 1

export PATH=/usr/local/sbin:/usr/local/bin:"$PATH"

# ----------------------------------------------------
# UDEV + CLOCK
# ----------------------------------------------------
/sbin/udevd --daemon >/dev/null 2>&1
/sbin/udevadm trigger --action=add >/dev/null 2>&1 &

while [ ! -e /dev/rtc0 ]; do usleep 50000; done
/sbin/hwclock -u -s &

/sbin/ifconfig lo 127.0.0.1 up
/sbin/route add 127.0.0.1 lo >/dev/null 2>&1 &

/sbin/ldconfig 2>/dev/null
/sbin/udevadm settle --timeout=5

# ----------------------------------------------------
# NETWORK: LACP BONDING
# ----------------------------------------------------
echo "----------------------------------------------------"
echo "🚀 Starting Network Configuration: LACP Bond0"
echo "----------------------------------------------------"

echo -n "Step 1: Loading bonding module... "
if modprobe bonding; then
    echo "OK"
else
    echo "FAILED"
    echo "❌ Bonding unavailable. Network disabled."
fi

echo -n "Step 2: Ensuring bond0 exists... "
if [ ! -d "/sys/class/net/bond0" ]; then
    echo +bond0 > /sys/class/net/bonding_masters && echo "CREATED"
else
    echo "EXISTS"
fi

ifconfig bond0 down 2>/dev/null

echo "Step 3: Configuring LACP..."
echo 4   > /sys/class/net/bond0/bonding/mode
echo 100 > /sys/class/net/bond0/bonding/miimon
echo 1   > /sys/class/net/bond0/bonding/lacp_rate
echo 1   > /sys/class/net/bond0/bonding/xmit_hash_policy

# Auto-detect interfaces
echo "Step 4: Detecting interfaces..."
PHYS_IFACES=$(ls /sys/class/net | grep -E '^e')

for iface in $PHYS_IFACES; do
    if [ "$iface" != "bond0" ]; then
        echo "   -> Enslaving $iface"
        ifconfig "$iface" down
        echo "+$iface" > /sys/class/net/bond0/bonding/slaves
    fi
done

echo "Step 5: Static network config..."
ifconfig bond0 192.168.10.230 netmask 255.255.255.0 up
route add default gw 192.168.10.253 bond0
echo "nameserver 192.168.10.252" > /etc/resolv.conf

# ----------------------------------------------------
# LACP SYNC
# ----------------------------------------------------
echo "----------------------------------------------------"
echo "⏳ Synchronizing LACP Link..."

COUNT=0
MAX=30
LINK_UP=false

while [ $COUNT -lt $MAX ]; do
    if [ "$(cat /sys/class/net/bond0/operstate 2>/dev/null)" = "up" ]; then
        echo "✅ Link UP (${COUNT}s)"
        LINK_UP=true
        break
    fi
    printf "\rWaiting... %ds/%ds" $COUNT $MAX
    sleep 1
    COUNT=$((COUNT+1))
done
echo ""

if [ "$LINK_UP" = "true" ]; then
    echo -n "🔍 Testing connectivity... "
    sleep 1
    if ping -c 3 -W 5 192.168.10.253 >/dev/null; then
        echo "OK"
    else
        echo "FAILED"
    fi
else
    echo "❌ LACP failed"
fi

echo "----------------------------------------------------"

# ----------------------------------------------------
# SYSTEM FIXES
# ----------------------------------------------------
[ ! -d /lib64 ] && ln -s /lib /lib64

# Keymap
if [ -e /home/tc/keymap ]; then
    KEYMAP=$(cat /home/tc/keymap)
    keymapfile=$(find /usr/share/kmap/ -name "${KEYMAP}.kmap")
    loadkmap < "$keymapfile"
fi

# Drive / Opal detection and console TUI are handled in sedunlocksrv (scanDrives, consoleInterface).

# ----------------------------------------------------
# START SERVICE
# ----------------------------------------------------
cd /usr/local/sbin/sedunlocksrv/

echo "🚀 Starting sedunlocksrv..."
exec ./sedunlocksrv

# ----------------------------------------------------
# FALLBACK (only if exec fails)
# ----------------------------------------------------
echo "❌ sedunlocksrv exited unexpectedly"

sleep 5
reboot -f
