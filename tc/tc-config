#!/bin/busybox ash

# ----------------------------------------------------
# Custom Tiny Core Linux RC Script
# ----------------------------------------------------

restore_terminal() {
    stty sane 2>/dev/null || true
    printf '\033[?25h'
    echo
    echo "[!] Terminal restored"
}

trap restore_terminal EXIT

dmesg -n 3
printf '\033[?25l'
stty cbreak min 1

export PATH=/usr/local/sbin:/usr/local/bin:"$PATH"

# ----------------------------------------------------
# UDEV + CLOCK
# ----------------------------------------------------
/sbin/udevd --daemon >/dev/null 2>&1
/sbin/udevadm trigger --action=add >/dev/null 2>&1 &

while [ ! -e /dev/rtc0 ]; do usleep 50000; done
/sbin/hwclock -u -s &

/sbin/ifconfig lo 127.0.0.1 up
/sbin/route add 127.0.0.1 lo >/dev/null 2>&1 &

/sbin/ldconfig 2>/dev/null
/sbin/udevadm settle --timeout=5

# ----------------------------------------------------
# Runtime config
# ----------------------------------------------------
EXPERT_PASSWORD_HASH=""
PASSWORD_COMPLEXITY_ON="true"
MIN_PASSWORD_LENGTH="12"
REQUIRE_UPPER="true"
REQUIRE_LOWER="true"
REQUIRE_NUMBER="true"
REQUIRE_SPECIAL="true"

[ -f /etc/sedunlocksrv.conf ] && . /etc/sedunlocksrv.conf
export EXPERT_PASSWORD_HASH
export PASSWORD_COMPLEXITY_ON
export MIN_PASSWORD_LENGTH
export REQUIRE_UPPER
export REQUIRE_LOWER
export REQUIRE_NUMBER
export REQUIRE_SPECIAL

if [ -x /usr/local/sbin/sedunlocksrv-net ]; then
    /usr/local/sbin/sedunlocksrv-net --configure || true
else
    echo "[net] Network helper unavailable; console unlock will still start"
fi

# ----------------------------------------------------
# SYSTEM FIXES
# ----------------------------------------------------
[ ! -d /lib64 ] && ln -s /lib /lib64

# Keymap
if [ -e /home/tc/keymap ]; then
    KEYMAP=$(cat /home/tc/keymap)
    keymapfile=$(find /usr/share/kmap/ -name "${KEYMAP}.kmap")
    if [ -n "${keymapfile}" ] && [ -f "${keymapfile}" ]; then
        loadkmap < "$keymapfile"
    else
        echo "[keymap] Requested keymap not found: ${KEYMAP}"
    fi
fi

# ----------------------------------------------------
# START SERVICE
# ----------------------------------------------------
cd /usr/local/sbin/sedunlocksrv/

echo "Starting sedunlocksrv..."
exec ./sedunlocksrv

# ----------------------------------------------------
# FALLBACK (only if exec fails)
# ----------------------------------------------------
echo "sedunlocksrv exited unexpectedly"
sleep 30
reboot -f
