# Copy to build.conf in this directory (or pass --config=/path/to/file).
# Variables are bash snippets: quoted values for strings with spaces.
# CLI flags override anything set here. Run with an unknown flag to print usage.

# --- Paths ---
# CACHEDIR="cache"              #
# BUILD_TMPDIR="img.tmp"        #

# --- Image / Tiny Core fetch ---
# KEXEC_VER="2.0.29"            # version of kexec to download from kernel.org
# TCURL="http://distro.ibiblio.org/tinycorelinux/15.x/x86_64"
# INPUTISO="TinyCorePure64-current.iso"

# --- Linux command line baked into GRUB (PBA kernel) ---
# BOOTARGS="libata.allow_tpm=1"

# --- Build behavior ---
# CLEAN_MODE=false              # true: remove cache/tmp/images/generated certs/app binary, then exit
# SSHBUILD=false                # true: same as ./build.sh --ssh
# TLS_CERT_PATH=""              # optional custom TLS cert copied to sedunlocksrv/server.crt
# TLS_KEY_PATH=""               # optional custom TLS key copied to sedunlocksrv/server.key
# TLS_SERVER_NAME=""            # required with custom TLS cert/key; SSH UI verifies this cert name over loopback using curl --resolve
# TLS_CA_CERT_PATH=""           # optional CA bundle for SSH helper when custom cert chains to an internal/private CA
# SSH_CURL_INSECURE="auto"      # auto: trust bundled self-signed cert; use normal CA validation for custom certs; true forces curl -k
# DEBUG_LEVEL="1"               # 0=verbose trace, 1=normal progress (default), 2=quiet
# EXPERT_PASSWORD=""            # optional; if empty, build.sh will prompt you to enter a password (no complexity requirements)

# --- PBA runtime (wired into tc-config where supported) ---
# build.sh validates these settings after loading build.conf and CLI overrides.
# Static IPv4 builds fail early if IP_ADDR, NETMASK, GATEWAY, or DNS is invalid.
# KEYMAP=""                     # e.g. fr-latin9 → adds kmaps.tcz and /home/tc/keymap
# EXCLUDE_NETDEV=""             # interfaces to skip entirely, e.g. "eth0 eno2"
# NET_MODE="single"             # single | bond
# NET_IFACES=""                 # interfaces to manage, e.g. "eth0 eth1"; empty = autodetect
# NET_DHCP="true"               # true = DHCP, false = static IPv4
# IP_ADDR="192.168.10.2"        # used when NET_DHCP=false
# NETMASK="255.255.255.0"       # used when NET_DHCP=false
# GATEWAY="192.168.10.1"        # optional, used when NET_DHCP=false
# DNS="192.168.10.1"            # optional, one or more DNS servers separated by spaces
# BOND_MODE="4"                 # explicit bond mode default: 4 = 802.3ad/LACP
# BOND_MIIMON="100"             # link monitor interval in ms
# BOND_LACP_RATE="1"            # 1 = fast LACPDU rate
# BOND_XMIT_HASH_POLICY="1"     # default transmit hash policy

# --- Password Policy (applies to web UI password change) ---
# PASSWORD_COMPLEXITY_ON="true" # true/false to enable/disable password complexity enforcement
# MIN_PASSWORD_LENGTH="12"      # minimum password length (when complexity is on)
# REQUIRE_UPPER="true"          # require uppercase letters (A-Z)
# REQUIRE_LOWER="true"          # require lowercase letters (a-z)
# REQUIRE_NUMBER="true"         # require numeric digits (0-9)
# REQUIRE_SPECIAL="true"        # require special characters

# --- Firmware settling delays ---
# SETTLE_FACTOR=""              # scale all firmware settling delays; default 1.0 (e.g. 0.5 = half, 2.0 = double)

# --- sedutil source (empty or unset = Drive-Trust-Alliance) ---
# SEDUTIL_FORK=""               # or ChubbyAnt / chubbyant

# --- GitHub release linking ---
# REPO_URL=""                   # e.g. "https://github.com/YourUser/sedunlocksrv-pba"; build tag links to releases when set + HEAD has a git tag
